# Copy to .env.production and fill in values from Hostinger hPanel → Databases → MySQL.
# Do NOT commit .env.production (gitignored).
#
# Used by:
#   - .\scripts\migrate-production-mysql.ps1  (local EF migrations against Hostinger DB)
#   - optional local Production API runs (Program.cs loads this file into env)

# Hostinger MySQL (Remote MySQL host from hPanel)
MYSQL_HOST=h5g5-db.hstgr.io
MYSQL_PORT=3306
MYSQL_DATABASE=u910121167_HVdBWy0pE_ecms
MYSQL_USER=u910121167_HVdBWy0pE_ecms
# If your password contains # or other special characters, wrap it in double quotes:
# MYSQL_PASSWORD="my#secret"

# Alternative: full connection string (overrides MYSQL_* above when set)
# ConnectionStrings__DefaultConnection=Server=h5g5-db.hstgr.io;Port=3306;Database=...;User=...;Password=...;SslMode=Required;

# Required for production API (min 32 characters). Same value as Railway Jwt__Key.
JWT_KEY=CHANGE-ME-use-a-long-random-secret-at-least-32-chars

# Required for production API. Same value as Railway LOGICTECK_API_KEY.
Logicteck__ApiKey=CHANGE-ME-logicteck-shared-secret
