# Copy to .env.production and fill in values from Hostinger hPanel → Databases → MySQL.
# Do NOT commit .env.production (gitignored).

# Hostinger MySQL (Remote MySQL host from hPanel, e.g. mysql123.hostinger.com)
MYSQL_HOST=mysql.hostinger.com
MYSQL_PORT=3306
MYSQL_DATABASE=u910121167_HVdBWy0pE_ecms
MYSQL_USER=u910121167_HVdBWy0pE_ecms
# If your password contains # or other special characters, wrap it in double quotes:
# MYSQL_PASSWORD="my#secret"

# Optional: full connection string overrides the parts above
# ConnectionStrings__DefaultConnection=Server=...;Port=3306;Database=...;User=...;Password=...;SslMode=Required;

# Production JWT secret (min 32 characters)
JWT_KEY=CHANGE-ME-use-a-long-random-secret-at-least-32-chars
